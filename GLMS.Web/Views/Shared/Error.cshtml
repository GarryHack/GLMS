@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="page-header">
    <div>
        <h1 style="color:var(--danger)">Something went wrong</h1>
        <div class="page-sub">An unexpected error occurred while processing your request</div>
    </div>
    <a href="/" class="btn-glms-outline">
        <i class="bi bi-house-door"></i>
        Back to Dashboard
    </a>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="detail-card">
            <div class="detail-card-header" style="background:#fef2f2;color:#991b1b;border-color:#fecaca">
                <i class="bi bi-exclamation-octagon-fill"></i>
                Error Details
            </div>
            <div class="detail-card-body">
                @if (Model.ShowRequestId)
                {
                    <div class="detail-row">
                        <div class="detail-label">Request ID</div>
                        <div class="detail-value text-mono" style="font-size:12px">@Model.RequestId</div>
                    </div>
                }
                <div class="detail-row" style="border-bottom:none">
                    <div class="detail-label">Help</div>
                    <div class="detail-value" style="font-size:13px;color:var(--text-secondary)">
                        If this error persists, contact your system administrator with the Request ID above.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
