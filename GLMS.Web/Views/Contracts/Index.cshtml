@model IEnumerable<GLMS.Web.Models.Contract>
@using GLMS.Web.Models
@{
    ViewData["Title"] = "Contracts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Contracts</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Contract</a>
</div>

<form asp-action="Index" method="get" class="card card-body bg-light mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label fw-semibold">Status</label>
            <select name="status" class="form-select">
                <option value="">-- All Statuses --</option>
                @foreach (ContractStatus s in ViewBag.StatusList)
                {
                    var selected = ViewBag.SelectedStatus != null && ViewBag.SelectedStatus == s ? "selected" : "";
                    <option value="@s" selected="@(ViewBag.SelectedStatus != null && ViewBag.SelectedStatus == s)">@s</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold">From Date</label>
            <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold">To Date</label>
            <input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control" />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-secondary">Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No contracts match the current filter.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Client</th>
                    <th>Service Level</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                    <th class="text-center">PDF</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contract in Model)
                {
                    var badgeClass = contract.Status switch
                    {
                        ContractStatus.Active  => "badge bg-success",
                        ContractStatus.Expired => "badge bg-danger",
                        ContractStatus.OnHold  => "badge bg-warning text-dark",
                        _                      => "badge bg-secondary"
                    };
                    <tr>
                        <td class="fw-semibold">@contract.Client.Name</td>
                        <td>@contract.ServiceLevel</td>
                        <td>@contract.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>@contract.EndDate.ToString("yyyy-MM-dd")</td>
                        <td><span class="@badgeClass">@contract.Status</span></td>
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(contract.SignedAgreementPath))
                            {
                                <a asp-action="Download" asp-route-id="@contract.Id"
                                   class="btn btn-sm btn-outline-danger" title="Download PDF">PDF</a>
                            }
                            else
                            {
                                <span class="text-muted small">None</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@contract.Id"
                               class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-action="Edit" asp-route-id="@contract.Id"
                               class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@contract.Id"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
