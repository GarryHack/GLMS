@model IEnumerable<GLMS.Web.Models.Contract>
@using GLMS.Web.Models
@{
    ViewData["Title"] = "Contracts";
}

<div class="page-header">
    <div>
        <h1>Contracts</h1>
        <div class="page-sub">Freight contract management hub</div>
    </div>
    <a asp-action="Create" class="btn-glms-primary">
        <i class="bi bi-plus-circle"></i>
        New Contract
    </a>
</div>

<!-- Filter Bar -->
<form asp-action="Index" method="get">
    <div class="filter-bar">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label" style="font-size:12px;font-weight:700;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.5px">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    @foreach (ContractStatus s in ViewBag.StatusList)
                    {
                        <option value="@s" selected="@(ViewBag.SelectedStatus != null && ViewBag.SelectedStatus == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" style="font-size:12px;font-weight:700;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.5px">From Date</label>
                <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label" style="font-size:12px;font-weight:700;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.5px">To Date</label>
                <input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control form-control-sm" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn-glms-primary" style="padding:8px 16px;font-size:13px">
                    <i class="bi bi-funnel"></i>
                    Filter
                </button>
                <a asp-action="Index" class="btn-glms-outline" style="padding:8px 14px;font-size:13px">
                    <i class="bi bi-x-circle"></i>
                    Clear
                </a>
            </div>
        </div>
    </div>
</form>

<div class="glms-table-wrapper">
    <div class="glms-table-header">
        <h5><i class="bi bi-file-earmark-text me-2 text-primary"></i>Contract List</h5>
        <span class="status-badge status-draft">@Model.Count() result@(Model.Count() == 1 ? "" : "s")</span>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="bi bi-file-earmark-text"></i></div>
            <h5>No contracts found</h5>
            <p>No contracts match the current filter, or none have been created yet.</p>
            <a asp-action="Create" class="btn-glms-primary">
                <i class="bi bi-plus-circle"></i>
                Create Contract
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table glms-table">
                <thead>
                    <tr>
                        <th>Client</th>
                        <th>Service Level</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th class="text-center">PDF</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var contract in Model)
                    {
                        var badgeClass = contract.Status switch
                        {
                            ContractStatus.Active  => "status-active",
                            ContractStatus.Expired => "status-expired",
                            ContractStatus.OnHold  => "status-onhold",
                            _                      => "status-draft"
                        };
                        <tr>
                            <td>
                                <div class="fw-600">@contract.Client.Name</div>
                                <div style="font-size:12px;color:var(--text-secondary)">
                                    <i class="bi bi-geo-alt"></i> @contract.Client.Region
                                </div>
                            </td>
                            <td style="font-size:13px">@contract.ServiceLevel</td>
                            <td style="font-size:13px;color:var(--text-secondary)">@contract.StartDate.ToString("dd MMM yyyy")</td>
                            <td style="font-size:13px;color:var(--text-secondary)">@contract.EndDate.ToString("dd MMM yyyy")</td>
                            <td><span class="status-badge @badgeClass">@contract.Status</span></td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(contract.SignedAgreementPath))
                                {
                                    <a asp-action="Download" asp-route-id="@contract.Id"
                                       class="btn-icon pdf" title="Download PDF">
                                        <i class="bi bi-file-earmark-pdf"></i>
                                    </a>
                                }
                                else
                                {
                                    <span style="font-size:12px;color:#cbd5e1">—</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-action="Details" asp-route-id="@contract.Id"
                                       class="btn-icon view" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@contract.Id"
                                       class="btn-icon edit" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@contract.Id"
                                       class="btn-icon del" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
