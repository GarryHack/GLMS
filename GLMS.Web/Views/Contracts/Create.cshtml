@model GLMS.Web.Models.Contract
@using GLMS.Web.Models
@{
    ViewData["Title"] = "New Contract";
}

<h2 class="mb-4">New Contract</h2>

<div class="row">
    <div class="col-md-7">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="ClientId" class="form-label fw-semibold">Client</label>
                <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select">
                    <option value="">-- Select a Client --</option>
                </select>
                <span asp-validation-for="ClientId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ServiceLevel" class="form-label fw-semibold"></label>
                <input asp-for="ServiceLevel" class="form-control" placeholder="e.g. Standard, Premium, Express" />
                <span asp-validation-for="ServiceLevel" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="StartDate" class="form-label fw-semibold"></label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="EndDate" class="form-label fw-semibold"></label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label fw-semibold"></label>
                <select asp-for="Status"
                        asp-items="Html.GetEnumSelectList<ContractStatus>()"
                        class="form-select"></select>
                <span asp-validation-for="Status" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label for="agreementFile" class="form-label fw-semibold">
                    Signed Agreement <span class="text-muted fw-normal">(PDF only, optional)</span>
                </label>
                <input type="file" name="agreementFile" id="agreementFile"
                       class="form-control" accept=".pdf" />
                <span asp-validation-for="SignedAgreementPath" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Contract</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
