@model GLMS.Web.Models.Contract
@using GLMS.Web.Models
@{
    ViewData["Title"] = "Edit Contract";
}

<div class="page-header">
    <div>
        <h1>Edit Contract</h1>
        <div class="page-sub">Contract #@Model.Id</div>
    </div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn-glms-outline">
        <i class="bi bi-arrow-left"></i>
        Back to Details
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="glms-form-card">
            <div class="form-header">
                <div class="form-header-icon">
                    <i class="bi bi-pencil-square"></i>
                </div>
                <div>
                    <div style="font-weight:700;font-size:15px">Edit Contract Details</div>
                    <div style="font-size:12px;color:var(--text-secondary)">Update the fields and save</div>
                </div>
            </div>

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div class="form-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-flex align-items-center gap-2 mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <div></div>
                    </div>

                    <input asp-for="Id" type="hidden" />

                    <div class="form-section-title">Basic Information</div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="ClientId" class="form-label">Client</label>
                            <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select"></select>
                            <span asp-validation-for="ClientId" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status"
                                    asp-items="Html.GetEnumSelectList<ContractStatus>()"
                                    class="form-select"></select>
                            <span asp-validation-for="Status" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ServiceLevel" class="form-label">Service Level</label>
                        <input asp-for="ServiceLevel" class="form-control" />
                        <span asp-validation-for="ServiceLevel" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-section-title mt-2">Contract Period</div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label">Start Date</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-calendar3"></i></span>
                                <input asp-for="StartDate" type="date" class="form-control" />
                            </div>
                            <span asp-validation-for="StartDate" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label">End Date</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-calendar3"></i></span>
                                <input asp-for="EndDate" type="date" class="form-control" />
                            </div>
                            <span asp-validation-for="EndDate" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="form-section-title mt-2">Documents</div>

                    @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                    {
                        <div class="d-flex align-items-center gap-3 mb-3 p-3" style="background:#f0fdf4;border:1px solid #a7f3d0;border-radius:var(--radius-sm)">
                            <i class="bi bi-file-earmark-pdf-fill text-danger fs-4"></i>
                            <div style="flex:1">
                                <div style="font-size:13px;font-weight:600;color:#065f46">Current file</div>
                                <div style="font-size:12px;color:#047857">@System.IO.Path.GetFileName(Model.SignedAgreementPath)</div>
                            </div>
                            <a asp-action="Download" asp-route-id="@Model.Id"
                               class="btn-glms-outline" style="font-size:12px;padding:6px 12px">
                                <i class="bi bi-download"></i>
                                Download
                            </a>
                        </div>
                    }

                    <div class="mb-2">
                        <label for="agreementFile" class="form-label">
                            @(string.IsNullOrEmpty(Model.SignedAgreementPath) ? "Upload Signed Agreement" : "Replace PDF")
                            <span style="font-weight:400;color:var(--text-secondary)"> (PDF only)</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-file-earmark-pdf text-danger"></i></span>
                            <input type="file" name="agreementFile" id="agreementFile"
                                   class="form-control" accept=".pdf" />
                        </div>
                        @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                        {
                            <div class="form-text">Leave blank to keep the existing file.</div>
                        }
                        <span asp-validation-for="SignedAgreementPath" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="form-footer">
                    <button type="submit" class="btn-glms-primary">
                        <i class="bi bi-check-circle"></i>
                        Save Changes
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn-glms-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
