@model GLMS.Web.Models.Contract
@using GLMS.Web.Models
@{
    ViewData["Title"] = "Contract Details";

    var badgeClass = Model.Status switch
    {
        ContractStatus.Active  => "status-active",
        ContractStatus.Expired => "status-expired",
        ContractStatus.OnHold  => "status-onhold",
        _                      => "status-draft"
    };
}

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <div style="width:48px;height:48px;border-radius:12px;background:#f0fdf4;color:#059669;display:flex;align-items:center;justify-content:center;font-size:22px">
            <i class="bi bi-file-earmark-text"></i>
        </div>
        <div>
            <h1>Contract #@Model.Id</h1>
            <div class="page-sub">@Model.Client.Name — @Model.ServiceLevel</div>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-glms-primary">
            <i class="bi bi-pencil"></i>
            Edit
        </a>
        <a asp-action="Index" class="btn-glms-outline">
            <i class="bi bi-arrow-left"></i>
            Back
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="detail-card">
            <div class="detail-card-header">
                <i class="bi bi-info-circle"></i>
                Contract Info
            </div>
            <div class="detail-card-body">
                <div class="detail-row">
                    <div class="detail-label">Client</div>
                    <div class="detail-value">
                        <a asp-controller="Clients" asp-action="Details" asp-route-id="@Model.ClientId"
                           class="fw-600">@Model.Client.Name</a>
                    </div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Service Level</div>
                    <div class="detail-value">@Model.ServiceLevel</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Start Date</div>
                    <div class="detail-value">@Model.StartDate.ToString("dd MMM yyyy")</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">End Date</div>
                    <div class="detail-value">@Model.EndDate.ToString("dd MMM yyyy")</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Status</div>
                    <div class="detail-value">
                        <span class="status-badge @badgeClass">@Model.Status</span>
                    </div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Agreement</div>
                    <div class="detail-value">
                        @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                        {
                            <a asp-action="Download" asp-route-id="@Model.Id"
                               class="btn-glms-outline" style="font-size:12px;padding:6px 12px">
                                <i class="bi bi-file-earmark-pdf text-danger"></i>
                                Download PDF
                            </a>
                        }
                        else
                        {
                            <span style="font-size:13px;color:var(--text-secondary)">No file uploaded</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="glms-table-wrapper">
            <div class="glms-table-header">
                <h5>
                    <i class="bi bi-clipboard2-check me-2 text-primary"></i>
                    Service Requests
                    <span class="status-badge status-draft ms-2">@Model.ServiceRequests.Count</span>
                </h5>
                @if (Model.Status == ContractStatus.Active || Model.Status == ContractStatus.Draft)
                {
                    <a asp-controller="ServiceRequests" asp-action="Create"
                       class="btn-glms-primary" style="font-size:13px;padding:7px 14px">
                        <i class="bi bi-plus-circle"></i>
                        New Request
                    </a>
                }
            </div>

            @if (!Model.ServiceRequests.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-clipboard2"></i></div>
                    <h5>No service requests</h5>
                    <p>No requests have been linked to this contract yet.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table glms-table">
                        <thead>
                            <tr>
                                <th>Description</th>
                                <th class="text-end">Cost (USD)</th>
                                <th class="text-end">Cost (ZAR)</th>
                                <th>Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sr in Model.ServiceRequests)
                            {
                                var srBadge = sr.Status switch
                                {
                                    ServiceRequestStatus.Pending    => "status-pending",
                                    ServiceRequestStatus.InProgress => "status-inprogress",
                                    ServiceRequestStatus.Completed  => "status-completed",
                                    ServiceRequestStatus.Cancelled  => "status-cancelled",
                                    _                               => "status-pending"
                                };
                                <tr>
                                    <td style="font-size:13px">@sr.Description</td>
                                    <td class="text-end text-mono">$@sr.CostUSD.ToString("N2")</td>
                                    <td class="text-end text-mono">R @sr.CostZAR.ToString("N2")</td>
                                    <td><span class="status-badge @srBadge">@sr.Status</span></td>
                                    <td class="text-center">
                                        <a asp-controller="ServiceRequests" asp-action="Details"
                                           asp-route-id="@sr.Id" class="btn-icon view" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
