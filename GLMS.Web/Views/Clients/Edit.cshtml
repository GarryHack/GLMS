@model GLMS.Web.Models.Client
@{
    ViewData["Title"] = "Edit Client";
}

<h2 class="mb-4">Edit Client</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input asp-for="Id" type="hidden" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ContactDetails" class="form-label fw-semibold"></label>
                <textarea asp-for="ContactDetails" class="form-control" rows="3"></textarea>
                <span asp-validation-for="ContactDetails" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Region" class="form-label fw-semibold"></label>
                <input asp-for="Region" class="form-control" />
                <span asp-validation-for="Region" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
