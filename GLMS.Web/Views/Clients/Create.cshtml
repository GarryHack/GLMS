@model GLMS.Web.Models.Client
@{
    ViewData["Title"] = "New Client";
}

<h2 class="mb-4">New Client</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Acme Logistics" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ContactDetails" class="form-label fw-semibold"></label>
                <textarea asp-for="ContactDetails" class="form-control" rows="3"
                          placeholder="e.g. john@acme.com | +27 11 000 0000"></textarea>
                <span asp-validation-for="ContactDetails" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Region" class="form-label fw-semibold"></label>
                <input asp-for="Region" class="form-control" placeholder="e.g. Sub-Saharan Africa" />
                <span asp-validation-for="Region" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Client</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
