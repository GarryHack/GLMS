@model IEnumerable<GLMS.Web.Models.Client>
@{
    ViewData["Title"] = "Clients";
}

<div class="page-header">
    <div>
        <h1>Clients</h1>
        <div class="page-sub">All registered logistics clients</div>
    </div>
    <a asp-action="Create" class="btn-glms-primary">
        <i class="bi bi-person-plus"></i>
        New Client
    </a>
</div>

<div class="glms-table-wrapper">
    <div class="glms-table-header">
        <h5><i class="bi bi-people me-2 text-primary"></i>Client Registry</h5>
        <span class="status-badge status-draft">@Model.Count() total</span>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="bi bi-people"></i></div>
            <h5>No clients yet</h5>
            <p>Add your first client to start managing contracts.</p>
            <a asp-action="Create" class="btn-glms-primary">
                <i class="bi bi-person-plus"></i>
                Add First Client
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table glms-table">
                <thead>
                    <tr>
                        <th>Client Name</th>
                        <th>Contact Details</th>
                        <th>Region</th>
                        <th class="text-center">Contracts</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var client in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:34px;height:34px;border-radius:8px;background:#dbeafe;color:#1d4ed8;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;flex-shrink:0">
                                        @client.Name[0]
                                    </div>
                                    <span class="fw-600">@client.Name</span>
                                </div>
                            </td>
                            <td style="color:var(--text-secondary);font-size:13px">@client.ContactDetails</td>
                            <td>
                                <span class="d-flex align-items-center gap-1" style="font-size:13px">
                                    <i class="bi bi-geo-alt text-muted"></i>
                                    @client.Region
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="status-badge status-draft">@client.Contracts.Count contract@(client.Contracts.Count == 1 ? "" : "s")</span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-action="Details" asp-route-id="@client.Id"
                                       class="btn-icon view" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@client.Id"
                                       class="btn-icon edit" title="Edit Client">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@client.Id"
                                       class="btn-icon del" title="Delete Client">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
