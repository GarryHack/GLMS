@model IEnumerable<GLMS.Web.Models.Client>
@{
    ViewData["Title"] = "Clients";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Clients</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Client</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No clients found. Add your first client to get started.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Contact Details</th>
                    <th>Region</th>
                    <th class="text-center">Contracts</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in Model)
                {
                    <tr>
                        <td class="fw-semibold">@client.Name</td>
                        <td>@client.ContactDetails</td>
                        <td>@client.Region</td>
                        <td class="text-center">
                            <span class="badge bg-secondary">@client.Contracts.Count</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@client.Id"
                               class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-action="Edit" asp-route-id="@client.Id"
                               class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@client.Id"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
