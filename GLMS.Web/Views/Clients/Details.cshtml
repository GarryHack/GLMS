@model GLMS.Web.Models.Client
@using GLMS.Web.Models
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <h2 class="mb-0">@Model.Name</h2>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Clients</a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header fw-semibold">Client Details</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Contact</dt>
                    <dd class="col-sm-8">@Model.ContactDetails</dd>

                    <dt class="col-sm-4">Region</dt>
                    <dd class="col-sm-8">@Model.Region</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Contracts <span class="badge bg-secondary">@Model.Contracts.Count</span></h4>
    <a asp-controller="Contracts" asp-action="Create" class="btn btn-sm btn-primary">+ New Contract</a>
</div>

@if (!Model.Contracts.Any())
{
    <div class="alert alert-info">This client has no contracts yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Service Level</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contract in Model.Contracts.OrderByDescending(c => c.StartDate))
                {
                    <tr>
                        <td>@contract.ServiceLevel</td>
                        <td>@contract.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>@contract.EndDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @{
                                var badgeClass = contract.Status switch
                                {
                                    ContractStatus.Active  => "badge bg-success",
                                    ContractStatus.Expired => "badge bg-danger",
                                    ContractStatus.OnHold  => "badge bg-warning text-dark",
                                    _                      => "badge bg-secondary"
                                };
                            }
                            <span class="@badgeClass">@contract.Status</span>
                        </td>
                        <td class="text-end">
                            <a asp-controller="Contracts" asp-action="Details" asp-route-id="@contract.Id"
                               class="btn btn-sm btn-outline-secondary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
