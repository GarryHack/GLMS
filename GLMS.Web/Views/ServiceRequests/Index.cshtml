@model IEnumerable<GLMS.Web.Models.ServiceRequest>
@using GLMS.Web.Models
@{
    ViewData["Title"] = "Service Requests";
}

<div class="page-header">
    <div>
        <h1>Service Requests</h1>
        <div class="page-sub">Freight service requests across all contracts</div>
    </div>
    <a asp-action="Create" class="btn-glms-primary">
        <i class="bi bi-send-plus"></i>
        New Request
    </a>
</div>

<div class="glms-table-wrapper">
    <div class="glms-table-header">
        <h5><i class="bi bi-clipboard2-check me-2 text-primary"></i>All Service Requests</h5>
        <span class="status-badge status-draft">@Model.Count() total</span>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="bi bi-clipboard2-check"></i></div>
            <h5>No service requests</h5>
            <p>Create a service request against an active contract to get started.</p>
            <a asp-action="Create" class="btn-glms-primary">
                <i class="bi bi-send-plus"></i>
                Create Request
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table glms-table">
                <thead>
                    <tr>
                        <th>Client / Contract</th>
                        <th>Description</th>
                        <th class="text-end">Cost (USD)</th>
                        <th class="text-end">Cost (ZAR)</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model)
                    {
                        var statusClass = request.Status switch
                        {
                            ServiceRequestStatus.Pending    => "status-pending",
                            ServiceRequestStatus.InProgress => "status-inprogress",
                            ServiceRequestStatus.Completed  => "status-completed",
                            ServiceRequestStatus.Cancelled  => "status-cancelled",
                            _                               => "status-pending"
                        };
                        <tr>
                            <td>
                                <div class="fw-600">@request.Contract.Client.Name</div>
                                <div style="font-size:12px;color:var(--text-secondary)">
                                    <i class="bi bi-file-earmark-text me-1"></i>@request.Contract.ServiceLevel
                                </div>
                            </td>
                            <td style="font-size:13px;max-width:260px">
                                <div style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@request.Description">
                                    @request.Description
                                </div>
                            </td>
                            <td class="text-end text-mono">$@request.CostUSD.ToString("N2")</td>
                            <td class="text-end text-mono" style="color:#059669;font-weight:600">R @request.CostZAR.ToString("N2")</td>
                            <td><span class="status-badge @statusClass">@request.Status</span></td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-action="Details" asp-route-id="@request.Id"
                                       class="btn-icon view" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@request.Id"
                                       class="btn-icon del" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
