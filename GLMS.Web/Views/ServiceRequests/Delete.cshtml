@model GLMS.Web.Models.ServiceRequest
@using GLMS.Web.Models
@{
    ViewData["Title"] = "Delete Service Request";
}

<h2 class="mb-4 text-danger">Delete Service Request</h2>

<div class="alert alert-warning">
    <strong>Warning:</strong> This will permanently delete this service request. This action cannot be undone.
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white fw-semibold">Request to be deleted</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Contract / Client</dt>
                    <dd class="col-sm-7">
                        @Model.Contract.Client.Name
                        <div class="text-muted small">@Model.Contract.ServiceLevel</div>
                    </dd>

                    <dt class="col-sm-5">Description</dt>
                    <dd class="col-sm-7">@Model.Description</dd>

                    <dt class="col-sm-5">Cost (USD)</dt>
                    <dd class="col-sm-7">$@Model.CostUSD.ToString("N2")</dd>

                    <dt class="col-sm-5">Cost (ZAR)</dt>
                    <dd class="col-sm-7">R @Model.CostZAR.ToString("N2")</dd>

                    <dt class="col-sm-5">Status</dt>
                    <dd class="col-sm-7">
                        @{
                            var statusClass = Model.Status switch
                            {
                                ServiceRequestStatus.Pending    => "badge bg-secondary",
                                ServiceRequestStatus.InProgress => "badge bg-primary",
                                ServiceRequestStatus.Completed  => "badge bg-success",
                                ServiceRequestStatus.Cancelled  => "badge bg-danger",
                                _                               => "badge bg-secondary"
                            };
                        }
                        <span class="@statusClass">@Model.Status</span>
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input asp-for="Id" type="hidden" />
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Yes, Delete Request</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
